# Only TOWONEL_IDENTITY__KEY_PATH is required; the rest have defaults.

TOWONEL_IDENTITY__KEY_PATH=/var/lib/towonel/node.key

TOWONEL_HUB__ENABLED=true
TOWONEL_HUB__LISTEN_ADDR=0.0.0.0:8443
TOWONEL_HUB__HEALTH_LISTEN_ADDR=0.0.0.0:9091
TOWONEL_HUB__PUBLIC_URL=https://hub.example.eu:8443
TOWONEL_HUB__OPERATOR_API_KEY_PATH=/var/lib/towonel/operator.key
TOWONEL_HUB__DNS_WEBHOOK_URL=https://dns-sidecar.internal/reconcile

TOWONEL_HUB__DATABASE__DRIVER=sqlite
# TOWONEL_HUB__DATABASE__DSN=postgresql://user:pass@host/db
# TOWONEL_HUB__DATABASE__MAX_OPEN_CONNS=25
# TOWONEL_HUB__DATABASE__MAX_IDLE_CONNS=10

# Pin peer node_ids to close the MITM window at first contact.
TOWONEL_HUB__PEERS=[{"url":"https://hub-b.example.eu:8443","node_id":"<64 hex>"}]
# TOWONEL_HUB__FEDERATION__SYNCHRONOUS_OPERATIONS=invite_redeem
# TOWONEL_ALLOW_UNPINNED_FEDERATION_PEERS=1

TOWONEL_TENANTS=[{"name":"alice","id":"<64 hex>","pq_public_key":"<base64url>","hostnames":["app.alice.test"]}]

TOWONEL_EDGE__ENABLED=true
TOWONEL_EDGE__LISTEN_ADDR=0.0.0.0:443
TOWONEL_EDGE__HEALTH_LISTEN_ADDR=0.0.0.0:9090
TOWONEL_EDGE__HUB_URLS=https://hub-a.example.eu:8443,https://hub-b.example.eu:8443
TOWONEL_EDGE__PUBLIC_ADDRESSES=edge-a.example.eu:443
# TOWONEL_EDGE__LISTEN_WORKERS=4

# Leave TLS unset for pure passthrough.
# TOWONEL_EDGE__TLS__CERT_DIR=/data/certs
# TOWONEL_EDGE__TLS__ACME_EMAIL=ops@example.eu
# TOWONEL_EDGE__TLS__ACME_STAGING=false
# TOWONEL_EDGE__TLS__HTTP_LISTEN_ADDR=0.0.0.0:80
